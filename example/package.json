{
  "name": "app-shortcuts-example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "sh -c 'EXPO_NO_TELEMETRY=1 npx expo start --localhost > /tmp/app-shortcuts-example-metro.log 2>&1 & METRO_PID=$!; trap \"kill $METRO_PID 2>/dev/null\" EXIT INT TERM; sleep 8; detox test --configuration ios.sim.debug'",
    "e2e:build:android": "detox build --configuration android.emu.e2e",
    "e2e:test:android": "detox test --configuration android.emu.e2e"
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~55.0.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "detox": "^20.51.0",
    "jest": "^30.3.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "nativeModulesDir": ".."
    }
  }
}
